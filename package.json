{
  "name": "agents-doctor",
  "version": "0.2.3",
  "description": "Deterministic CLI/CI checker for AGENTS.md agent instruction files.",
  "type": "module",
  "bin": {
    "agents-doctor": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "AGENTS.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "benchmark": "node scripts/benchmark/run-benchmark.mjs",
    "smoke": "node tests/smoke/cli-smoke.mjs",
    "smoke:pack": "node tests/smoke/pack-smoke.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "keywords": [
    "agents",
    "cli",
    "ci",
    "markdown",
    "validator"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "picomatch": "^4.0.4",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/picomatch": "^4.0.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
